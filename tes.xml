<mxfile host="app.diagrams.net">
  <diagram name="Flowchart ML KNN">
    <mxGraphModel dx="1200" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="600">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- START -->
        <mxCell id="start" value="START" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="200" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- Load Dataset -->
        <mxCell id="load" value="Load Dataset" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="200" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- Preprocessing -->
        <mxCell id="prep" value="Pre-processing Data (Cleaning &amp; Normalisasi)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="200" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Split -->
        <mxCell id="split" value="Split Data (Train &amp; Test)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="200" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- Training KNN -->
        <mxCell id="train" value="Training Model (K-Nearest Neighbors)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="660" y="200" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Evaluasi -->
        <mxCell id="eval" value="Evaluasi Model (Accuracy / MAE / MSE)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="200" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- Decision -->
        <mxCell id="decision" value="Model Sudah Optimal?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1120" y="190" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Perbaikan -->
        <mxCell id="fix" value="Tuning K (Hyperparameter)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1120" y="80" width="180" height="50" as="geometry"/>
        </mxCell>

        <!-- Simpan -->
        <mxCell id="save" value="Simpan Model" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1280" y="200" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- Implementasi -->
        <mxCell id="deploy" value="Implementasi (Streamlit)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1440" y="200" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Input -->
        <mxCell id="input" value="Input Data &amp; Prediksi" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1640" y="200" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Output -->
        <mxCell id="output" value="Output Hasil Prediksi" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1840" y="200" width="160" height="50" as="geometry"/>
        </mxCell>

        <!-- END -->
        <mxCell id="end" value="END" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="2020" y="200" width="80" height="40" as="geometry"/>
        </mxCell>

        <!-- Connections -->
        <mxCell edge="1" parent="1" source="start" target="load" style="endArrow=block;"/>
        <mxCell edge="1" parent="1" source="load" target="prep" style="endArrow=block;"/>
        <mxCell edge="1" parent="1" source="prep" target="split" style="endArrow=block;"/>
        <mxCell edge="1" parent="1" source="split" target="train" style="endArrow=block;"/>
        <mxCell edge="1" parent="1" source="train" target="eval" style="endArrow=block;"/>
        <mxCell edge="1" parent="1" source="eval" target="decision" style="endArrow=block;"/>

        <mxCell edge="1" parent="1" source="decision" target="save" value="Ya" style="endArrow=block;"/>
        <mxCell edge="1" parent="1" source="decision" target="fix" value="Tidak" style="endArrow=block;"/>

        <mxCell edge="1" parent="1" source="fix" target="train" style="endArrow=block;"/>

        <mxCell edge="1" parent="1" source="save" target="deploy" style="endArrow=block;"/>
        <mxCell edge="1" parent="1" source="deploy" target="input" style="endArrow=block;"/>
        <mxCell edge="1" parent="1" source="input" target="output" style="endArrow=block;"/>
        <mxCell edge="1" parent="1" source="output" target="end" style="endArrow=block;"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>